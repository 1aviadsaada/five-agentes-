# ============================================
#  הגדרות סביבה — צוות הסוכנים ליצירת תוכן
#  זוהי תבנית. העתק לקובץ .env ומלא בערכים אמיתיים:
#      cp .env.example .env
#  אל תכניס מפתחות אמיתיים לקובץ הזה — הוא נשמר ב-git.
# ============================================

# המפתח המרכזי — ה"מוח" של ראובן והצוות (Claude / Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# יובל — מעצב התמונות: מפתח ל-API ליצירת תמונות
IMAGE_GEN_API_KEY=your-image-api-key-here

# חן — החוקרת: מפתח ל-API לחיפוש/מחקר באינטרנט
SEARCH_API_KEY=your-search-api-key-here
